# ==========================================
# PENGATURAN ENVIRONMENT UNTUK VERCEL (PRODUCTION)
# ==========================================

# 1. URL dari database Turso Anda (dapatkan di dashboard turso.tech)
# Contoh: libsql://nama-database-anda.turso.io
TURSO_DATABASE_URL=

# 2. Auth Token dari database Turso Anda (buat di dashboard / CLI turso)
# Contoh: eyJhbGci...
TURSO_AUTH_TOKEN=

# 3. Kunci rahasia untuk login ke Admin CMS
# Silakan ubah menjadi kata sandi yang Anda inginkan saat deploy di Vercel
ADMIN_SECRET=rahasia_admin_website_123
